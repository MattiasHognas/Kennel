{
  "promptContext": {
    "previousOutput": false
  },
  "permissions": {
    "git": {
      "status": false,
      "diff": false,
      "history": false
    },
    "acp": {
      "readTextFile": true,
      "writeTextFile": true,
      "requestPermission": false,
      "createTerminal": true,
      "killTerminal": true,
      "terminalOutput": true,
      "releaseTerminal": true,
      "waitForTerminal": true
    }
  },
  "mcpServers": [
    {
      "transport": "stdio",
      "name": "playwright",
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }
  ]
}